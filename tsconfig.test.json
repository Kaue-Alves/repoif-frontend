{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo",
    "types": ["vite/client", "node", "vitest/globals"],
    "noEmit": true
  },
  /* Zera o `exclude` herdado do tsconfig.app.json — lá ele tira os testes; aqui eles são o alvo. */
  "exclude": [],
  "include": ["src/**/*.spec.ts", "src/**/*.spec.tsx", "src/test/**/*", "src/**/*.ts", "src/**/*.tsx"]
}
